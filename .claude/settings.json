{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git -C \"$CLAUDE_PROJECT_DIR\" fetch -q 2>/dev/null; git -C \"$CLAUDE_PROJECT_DIR\" pull --ff-only -q 2>/dev/null; true",
            "timeout": 30,
            "statusMessage": "원격 최신 동기화(git fetch+pull)",
            "suppressOutput": true
          }
        ]
      }
    ]
  }
}
